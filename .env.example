# Gridbert — Persönlicher Energie-Agent
# Kopiere diese Datei nach .env und setze deine Werte.

# --- Pflicht ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Auth (in Produktion ändern!) ---
SECRET_KEY=change-this-to-a-random-string

# --- Optional: Wiener Netze Smart Meter ---
# WIENER_NETZE_EMAIL=
# WIENER_NETZE_PASSWORD=

# --- Optional: ENTSO-E Spot-Preise ---
# ENTSOE_API_KEY=

# --- Optional: Datenbank (default: SQLite) ---
# DATABASE_URL=postgresql://user:pass@localhost/gridbert

# --- Optional: CORS Origins (default: localhost:5173,localhost:3000) ---
# CORS_ORIGINS=https://app.gridbert.at

# --- Optional: Legacy Ollama (für Self-Hosted ohne Claude) ---
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_VISION_MODEL=qwen2.5vl:7b

# --- Optional: Port (für docker-compose) ---
# PORT=5000
